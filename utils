

responses = {

    "solar": """
Solar panels convert sunlight into electricity.

Benefits:
- Clean energy
- Renewable source
- Reduces carbon emissions
""",

    "wind": """
Wind turbines generate electricity using wind energy.

Benefits:
- Sustainable
- Environment friendly
- Low operating cost
""",

    "renewable": """
Renewable energy comes from natural resources.

Examples:
- Solar
- Wind
- Hydropower
- Biomass
""",

    "sdg 7": """
SDG 7 stands for Affordable and Clean Energy.

Goals:
- Universal energy access
- Renewable energy adoption
- Energy efficiency
"""
}

def chatbot_response(user_input):

    user_input = user_input.lower()

    for keyword in responses:
        if keyword in user_input:
            return responses[keyword]

    return "Please ask about solar, wind, renewable energy, or SDG 7."